# =============================================================================
# kga-fastapi-integration-template — environment template
# =============================================================================
# This is a COMMITTED template. It holds KEY NAMES ONLY — never real secrets.
#
# Setup:
#   1. Copy this file to `.env`  ->  cp .env.example .env
#   2. Fill in the caller API keys (API_KEYS) and the provider credentials
#      (EXAMPLE_CLIENT_ID / EXAMPLE_CLIENT_SECRET) with real values.
#   3. Leave the rest at their defaults unless you need to override them.
#
# `.env` is gitignored and must NEVER be committed; this `.env.example`
# template IS committed. Do not put any real secret in this file.
# =============================================================================

# -----------------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------------

# Runtime environment: dev | prod
APP_ENV=dev

# Public base URL of this service. Drives the derived provider callback URL.
APP_BASE_URL=http://localhost:8000

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# On-disk auth token store (gitignored). Path is relative to the repo root.
TOKEN_STORE_PATH=.tokens/example_token.json

# -----------------------------------------------------------------------------
# Caller authentication (our own surface)
# -----------------------------------------------------------------------------

# Comma-separated list of caller API keys accepted in the X-API-Key header.
# Leave blank ONLY for local dev — an empty list leaves the surface unguarded.
# Set real values in your local .env before exposing this service.
API_KEYS=

# -----------------------------------------------------------------------------
# Provider credentials
#   Rename EXAMPLE_* to the concrete provider when building a real service.
# -----------------------------------------------------------------------------

# Base URL of the third-party provider API (not a secret).
EXAMPLE_API_BASE=https://api.example.com/v1

# SECRET — leave blank here; set the real value in your local .env
EXAMPLE_CLIENT_ID=

# SECRET — leave blank here; set the real value in your local .env
EXAMPLE_CLIENT_SECRET=
