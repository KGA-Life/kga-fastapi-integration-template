# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ---------------------------------------------------------------------------
# Virtualenvs
# ---------------------------------------------------------------------------
.venv/
venv/

# ---------------------------------------------------------------------------
# uv (keep uv.lock TRACKED — do not ignore it)
# ---------------------------------------------------------------------------
.uv/

# ---------------------------------------------------------------------------
# Secrets / local env
#   Ignore all .env files, but keep the committed template .env.example.
#   The negation MUST come after the .env* ignore for it to take effect.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Provider token store (the on-disk token file must never be committed)
# ---------------------------------------------------------------------------
.tokens/
*.token.json
*token*.json

# ---------------------------------------------------------------------------
# Docker scratch
# ---------------------------------------------------------------------------
*.pid

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.iml

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
